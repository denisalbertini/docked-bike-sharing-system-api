  "components": {
    "securitySchemes": {
      "EmployeeAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "OperatorAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Bike": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "51235fe8-76fe-47d0-bcb7-49760f09eff5"
          },
          "bikeSerial": {
            "type": "string",
            "example": "BI-001"
          },
          "brand": {
            "type": "string",
            "example": "Caloi"
          },
          "model": {
            "type": "string",
            "example": "Velox"
          },
          "manufactureYear": {
            "type": "number",
            "example": 2020
          },
          "status": {
            "example": "NEW",
            "type": "string",
            "enum": [
              "NEW",
              "AVAILABLE",
              "RENTED",
              "MAINTENANCE_REQUESTED",
              "UNDER_MAINTENANCE",
              "RETIRED"
            ]
          }
        },
        "required": [
          "id",
          "bikeSerial",
          "brand",
          "model",
          "manufactureYear",
          "status"
        ]
      },
      "NewBike": {
        "type": "object",
        "properties": {
          "bikeSerial": {
            "type": "string",
            "example": "BI-001"
          },
          "brand": {
            "type": "string",
            "example": "Caloi"
          },
          "model": {
            "type": "string",
            "example": "Velox"
          },
          "manufactureYear": {
            "type": "number",
            "example": 2020
          }
        },
        "required": [
          "bikeSerial",
          "brand",
          "model",
          "manufactureYear"
        ]
      },
      "UpdateBike": {
        "type": "object",
        "properties": {
          "brand": {
            "type": "string",
            "example": "Caloi"
          },
          "model": {
            "type": "string",
            "example": "Velox"
          }
        }
      },
      "BikeAdmission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "c9ebf37a-d07c-468d-a643-214eee5ff51e"
          },
          "requestedAt": {
            "type": "string",
            "example": "Sat Jun 14 2025 21:00:00 GMT-0300 (Horário Padrão de Brasília)"
          },
          "bikeId": {
            "type": "string",
            "example": "8b665731-39a9-4817-9f15-ec4d5e9ce3dc"
          },
          "dockId": {
            "type": "string",
            "example": "227c0110-4b12-45ad-ba6a-785a494fb6e0"
          }
        },
        "required": [
          "id",
          "requestedAt",
          "bikeId",
          "dockId"
        ]
      },
      "NewBikeAdmission": {
        "type": "object",
        "properties": {
          "bikeSerial": {
            "type": "string",
            "example": "BI-001"
          },
          "dockSerial": {
            "type": "string",
            "example": "DO-001"
          }
        },
        "required": [
          "bikeSerial",
          "dockSerial"
        ]
      },
      "BikeRemoval": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "c9ebf37a-d07c-468d-a643-214eee5ff51e"
          },
          "requestedAt": {
            "type": "string",
            "example": "Sat Jun 14 2025 21:00:00 GMT-0300 (Horário Padrão de Brasília)"
          },
          "bikeId": {
            "type": "string",
            "example": "8b665731-39a9-4817-9f15-ec4d5e9ce3dc"
          },
          "employeeId": {
            "type": "string",
            "example": "227c0110-4b12-45ad-ba6a-785a494fb6e0"
          }
        },
        "required": [
          "id",
          "requestedAt",
          "bikeId",
          "employeeId"
        ]
      },
      "NewBikeRemoval": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "string",
            "example": "227c0110-4b12-45ad-ba6a-785a494fb6e0"
          },
          "bikeSerial": {
            "type": "string",
            "example": "BI-001"
          },
          "dockSerial": {
            "type": "string",
            "example": "DO-001"
          },
          "action": {
            "example": "REPAIR",
            "type": "string",
            "enum": [
              "REPAIR",
              "RETIRE"
            ]
          }
        },
        "required": [
          "employeeId",
          "bikeSerial",
          "dockSerial",
          "action"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "errorType": {
            "type": "string",
            "enum": [
              "AUTHENTICATION_ERROR",
              "FORBIDDEN_ERROR",
              "FOREIGN_KEY_CONSTRAINT_ERROR",
              "INTERNAL_SERVER_ERROR",
              "NOT_FOUND_ERROR",
              "PRECONDITION_FAILED_ERROR",
              "UNIQUE_CONSTRAINT_ERROR",
              "VALIDATION_ERROR"
            ]
          },
          "errors": {
            "type": "array",
            "example": [
              "Error message 1",
              "Error message 2"
            ],
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "errorType",
          "errors"
        ]
      }
    },
    "examples": {
      "NotFoundError": {
        "value": {
          "errorType": "NOT_FOUND_ERROR",
          "errors": [
            "Records not found."
          ]
        }
      },
      "ValidationError": {
        "value": {
          "errorType": "VALIDATION_ERROR",
          "errors": [
            "Validation is on entity.field failed.",
            "Validation len on entity.anotherField failed."
          ]
        }
      },
      "UniqueConstraintError": {
        "value": {
          "errorType": "UNIQUE_CONSTRAINT_ERROR",
          "errors": [
            "duplicating key value violates unique constraint \"entity_field_key\""
          ]
        }
      },
      "PreconditionFailedError": {
        "value": {
          "errorType": "PRECONDITION_FAILED_ERROR",
          "errors": [
            "Instance is not STATUS"
          ]
        }
      }
    }
  }
